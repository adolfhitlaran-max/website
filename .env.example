# Example only. Do not put real secrets in this file.

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY

# Supabase Edge Function secrets
OPENROUTER_API_KEY=YOUR_OPENROUTER_KEY
OPENROUTER_MODEL=openrouter/free
HUGGINGFACE_API_KEY=YOUR_HUGGINGFACE_KEY
HF_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# Self-hosted AI should be reachable by Supabase only through HTTPS tunnel/proxy.
# Do not use localhost, LAN IPs, home public IPs, or raw port-forwarded Ollama URLs here.
LOCAL_OLLAMA_URL=https://YOUR_CLOUDFLARE_TUNNEL_OR_REVERSE_PROXY
OLLAMA_MODEL=llama3.2:3b

# Optional future music provider. Keep it behind HTTPS tunnel/proxy with auth/rate limits.
MUSICGEN_URL=https://YOUR_MUSICGEN_TUNNEL_OR_REVERSE_PROXY
MUSICGEN_PROXY_TOKEN=YOUR_SHARED_PROXY_TOKEN
HF_MUSIC_ENDPOINT=https://YOUR_HUGGINGFACE_MUSIC_ENDPOINT
